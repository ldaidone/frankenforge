{
    "name": "frankenforge/kernel",
    "description": "Zero-bloat FrankenPHP + HTMX kernel for staff engineers",
    "type": "project",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "FrankenForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrankenForge\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
