{
    "name": "ldaidone/frankenforge",
    "description": "Minimal FrankenPHP worker-mode kernel for building HTMX-first applications in raw PHP 8.3",
    "type": "project",
    "license": "Apache-2.0",
    "keywords": ["frankenphp", "htmx", "kernel", "worker-mode", "php"],
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "FrankenForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrankenForge\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
